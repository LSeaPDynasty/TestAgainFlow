# Application
APP_NAME=TestFlow API
APP_VERSION=1.0.0
DEBUG=False

# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=testflow
MYSQL_PASSWORD=testflow123
MYSQL_DATABASE=testflow

# Build DATABASE_URL
# DATABASE_URL=mysql+pymysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DATABASE}
DATABASE_URL=mysql+pymysql://testflow:testflow123@localhost:3306/testflow

# Redis
REDIS_URL=redis://localhost:6379/0

# RabbitMQ (optional, for RabbitMQ transport)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Execution Engine
ENGINE_TRANSPORT=ws
ENGINE_WS_URL=ws://localhost:8001/ws

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File Storage
SCREENSHOTS_DIR=./data/screenshots
BACKUPS_DIR=./data/backups
CUSTOM_FLOWS_DIR=./engine/custom_flows

# ADB
ADB_PATH=adb
